{
  "name": "clicky-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r test && vp run -r build",
    "check:arch": "node hack/check-arch.mjs",
    "predev:storybook": "node hack/check-arch.mjs",
    "dev:storybook": "vp run storybook#dev",
    "dev:kitchen-sink": "vp run kitchen-sink#dev",
    "build": "vp run -r build",
    "test": "vp run -r test",
    "test:e2e": "vp run e2e#test",
    "check": "vp check",
    "changeset": "vp exec changeset",
    "release": "vp run -r build && vp exec changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@voidzero-dev/vite-plus-darwin-arm64": "catalog:"
  }
}
