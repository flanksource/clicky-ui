{
  "name": "@flanksource/clicky-ui",
  "version": "0.2.1",
  "description": "Flanksource Clicky UI — React component library built on shadcn/ui with light/dark and density theming.",
  "homepage": "https://github.com/flanksource/clicky-ui#readme",
  "bugs": "https://github.com/flanksource/clicky-ui/issues",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/flanksource/clicky-ui.git",
    "directory": "packages/ui"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "./src/styles/**"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.js"
    },
    "./data": {
      "types": "./dist/data.d.ts",
      "import": "./dist/data.js"
    },
    "./clicky": {
      "types": "./dist/clicky.d.ts",
      "import": "./dist/clicky.js"
    },
    "./rpc": {
      "types": "./dist/rpc.d.ts",
      "import": "./dist/rpc.js"
    },
    "./api-explorer": {
      "types": "./dist/api-explorer.d.ts",
      "import": "./dist/api-explorer.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.js",
      "require": "./dist/tailwind-preset.cjs",
      "default": "./dist/tailwind-preset.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp dev",
    "build": "vite build && node scripts/build-styles.mjs && vp pack src/tailwind-preset.ts -f cjs --no-clean --sourcemap --no-minify",
    "test": "vp test",
    "check": "vp check"
  },
  "dependencies": {
    "@iconify/react": "catalog:",
    "@radix-ui/react-compose-refs": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@scalar/api-reference-react": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@storybook/react-vite": "10.3.5",
    "@tailwindcss/cli": "^4.2.4",
    "@tanstack/react-query": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "^4.2.4",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@shikijs/transformers": "^1.24.0",
    "@tanstack/react-query": "^5.0.0",
    "marked": "^15.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "shiki": "^1.24.0",
    "tailwindcss": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "@shikijs/transformers": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "marked": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  }
}
