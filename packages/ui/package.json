{
  "name": "@flanksource/clicky-ui",
  "version": "0.3.0",
  "description": "Flanksource Clicky UI — React component library built on shadcn/ui with light/dark and density theming.",
  "homepage": "https://github.com/flanksource/clicky-ui#readme",
  "bugs": "https://github.com/flanksource/clicky-ui/issues",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/flanksource/clicky-ui.git",
    "directory": "packages/ui"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "./src/styles/**"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js",
      "require": "./dist/hooks.cjs"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.js",
      "require": "./dist/components.cjs"
    },
    "./data": {
      "types": "./dist/data.d.ts",
      "import": "./dist/data.js",
      "require": "./dist/data.cjs"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js",
      "require": "./dist/icons.cjs"
    },
    "./clicky": {
      "types": "./dist/clicky.d.ts",
      "import": "./dist/clicky.js",
      "require": "./dist/clicky.cjs"
    },
    "./rpc": {
      "types": "./dist/rpc.d.ts",
      "import": "./dist/rpc.js",
      "require": "./dist/rpc.cjs"
    },
    "./chat": {
      "types": "./dist/chat.d.ts",
      "import": "./dist/chat.js",
      "require": "./dist/chat.cjs"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.js",
      "require": "./dist/ai.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.js",
      "require": "./dist/tailwind-preset.cjs",
      "default": "./dist/tailwind-preset.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "pnpm run build:icons && vite build && vite build --mode cjs && node scripts/build-styles.mjs",
    "build:icons": "tsx scripts/build-icons.ts",
    "build:icons:force": "tsx scripts/build-icons.ts --force",
    "test": "pnpm run build:icons && vitest run",
    "check": "pnpm run build:icons && tsc -b --noEmit && oxlint src --deny-warnings"
  },
  "dependencies": {
    "@flanksource/icons": "1.0.60",
    "@floating-ui/react": "catalog:",
    "@radix-ui/react-compose-refs": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@tanstack/react-query": "^5.66.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.7",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@ai-sdk/react": "catalog:",
    "@oxlint/plugins": "catalog:",
    "@storybook/react-vite": "10.3.5",
    "@tailwindcss/cli": "^4.2.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "ai": "catalog:",
    "jsdom": "^26.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-rnd": "^10.5.3",
    "recharts": "^3.8.1",
    "streamdown": "^2.5.0",
    "svgo": "^3.2.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@shikijs/langs": "^1.24.0",
    "@shikijs/themes": "^1.24.0",
    "@shikijs/transformers": "^1.24.0",
    "ai": "^6.0.0",
    "marked": "^15.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-rnd": "^10.5.0",
    "recharts": "^3.0.0",
    "shiki": "^1.24.0",
    "streamdown": "^2.5.0",
    "tailwindcss": "^3.4.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "streamdown": {
      "optional": true
    },
    "@ai-sdk/react": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "@shikijs/langs": {
      "optional": true
    },
    "@shikijs/themes": {
      "optional": true
    },
    "@shikijs/transformers": {
      "optional": true
    },
    "marked": {
      "optional": true
    },
    "shiki": {
      "optional": true
    },
    "react-rnd": {
      "optional": true
    }
  }
}
